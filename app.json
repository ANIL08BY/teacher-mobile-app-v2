{
  "expo": {
    "name": "Okul+",
    "owner": "anil84",
    "slug": "okul-plus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/okul-logo.png",
    "scheme": "teachermobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/okul-logo.png",
        "backgroundImage": "./assets/images/okul-logo.png",
        "monochromeImage": "./assets/images/okul-logo.png",
        "package": "com.anil84.okulplus",
        "versionCode": 1
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anil84.okulplus"
    },
    "extra": {
      "eas": {
        "projectId": "f8deeb8b-aaea-4303-a213-88c6d26dfd6e"
      }
    }
  },
  "web": {
    "output": "static",
    "favicon": "./assets/images/okul-logo.png"
  },
  "plugins": [
    "expo-router",
    [
      "expo-splash-screen",
      {
        "image": "./assets/images/okul-logo.png",
        "imageWidth": 200,
        "resizeMode": "contain",
        "backgroundColor": "#ffffff",
        "dark": {
          "backgroundColor": "#000000"
        }
      }
    ]
  ],
  "experiments": {
    "typedRoutes": true,
    "reactCompiler": true
  },
  "extra": {
    "router": {},
    "eas": {
      "projectId": "5ca70ce0-aa4d-4423-a458-ea855d2eb35f"
    }
  }
}
